---
// Footer.astro - Componente footer reutilizable
import { siteConfig } from '../data/site.config.js';
---

<footer class="bg-foreground text-background">
	<div class="max-w-7xl mx-auto px-6 py-12">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
			
			<!-- Logo y descripcion -->
			<div class="text-center md:text-left">
				<div class="flex items-center gap-3 justify-center md:justify-start mb-3">
					<div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center">
						<svg class="w-6 h-6 text-background" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
						</svg>
					</div>
					<span class="text-xl font-bold">InflvxDev</span>
				</div>
				<p class="text-background/70 text-sm">
					Construyendo soluciones digitales con pasion y creatividad
				</p>
			</div>
			
			<!-- Enlaces rapidos -->
			<div class="flex justify-center gap-6">
				{siteConfig.nav.map(link => (
					<a href={link.path} class="text-background/70 hover:text-primary transition-colors text-sm font-medium">
						{link.name}
					</a>
				))}
			</div>
			
			<!-- Redes sociales -->
			<div class="flex justify-center md:justify-end gap-3">
				<a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" 
				   class="w-10 h-10 bg-background/10 hover:bg-primary rounded-xl flex items-center justify-center transition-all hover:shadow-md"
				   title="GitHub">
					<svg fill="currentColor" class="w-5 h-5" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12"/></svg>
				</a>
				<a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer"
				   class="w-10 h-10 bg-background/10 hover:bg-primary rounded-xl flex items-center justify-center transition-all hover:shadow-md"
				   title="LinkedIn">
					<svg fill="currentColor" class="w-5 h-5" viewBox="0 0 24 24"><path d="M19 0H5a5 5 0 0 0-5 5v14a5 5 0 0 0 5 5h14a5 5 0 0 0 5-5V5a5 5 0 0 0-5-5M8 19H5V8h3zM6.5 6.732c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764M20 19h-3v-5.604c0-3.368-4-3.113-4 0V19h-3V8h3v1.765c1.396-2.586 7-2.777 7 2.476z"/></svg>
				</a>
				<a href={`mailto:${siteConfig.email}`} 
				   class="w-10 h-10 bg-background/10 hover:bg-primary rounded-xl flex items-center justify-center transition-all hover:shadow-md"
				   title="Email">
					<svg fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m3 8 7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2"/></svg>
				</a>
			</div>
		</div>
		
		<!-- Linea separadora y copyright -->
		<div class="border-t border-background/10 mt-8 pt-6 text-center">
			<p class="text-background/50 text-sm">
				© <span id="footer-year"></span> - InflvxDev
			</p>
		</div>
	</div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>
